rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }

    function isSignedIn() { 
      return request.auth != null && request.auth.token.email_verified == true; 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidTask(data) {
      return data.keys().hasAll(['userId', 'title', 'description', 'dueDate', 'priority', 'status', 'completionPhotoUrl', 'createdAt', 'updatedAt'])
        && data.userId == request.auth.uid
        && data.title is string && data.title.size() > 0 && data.title.size() <= 120
        && data.description is string && data.description.size() <= 1000
        && data.dueDate is number
        && data.priority in ['Low', 'Medium', 'High']
        && data.status in ['Pending', 'In Progress', 'Completed']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (data.status != 'Completed' || (data.completionPhotoUrl is string && data.completionPhotoUrl.size() > 0 && data.completionPhotoUrl.size() <= 1000000))
        && (data.status == 'Completed' || (data.completionPhotoUrl is string && data.completionPhotoUrl.size() == 0));
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(taskId)
        && incoming().keys().hasAll(['userId', 'title', 'description', 'dueDate', 'priority', 'status', 'completionPhotoUrl', 'createdAt', 'updatedAt'])
        && incoming().keys().size() == 9
        && isValidTask(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn()
        && isValidTask(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'dueDate', 'priority', 'status', 'completionPhotoUrl', 'updatedAt']);
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
